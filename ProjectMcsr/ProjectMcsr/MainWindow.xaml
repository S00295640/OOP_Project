    <Window x:Class="ProjectMcsr.MainWindow"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="MCSR Ranked Hub" Height="700" Width="1100"
            WindowStartupLocation="CenterScreen"
            Background="#081818">

        <Window.Resources>
            <SolidColorBrush x:Key="TextGreen" Color="#99FF66" />
            <SolidColorBrush x:Key="TitleBg" Color="#122B27" />
            
            <Style x:Key="LargeMenuButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="#122B27"/>
                <Setter Property="Foreground" Value="{StaticResource TextGreen}"/>
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontFamily" Value="/ProjectMcsr;component/Resources/#Minecrafter"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Margin" Value="0,0,0,20"/>
                <Setter Property="Padding" Value="30,25"/> <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border BorderBrush="White" 
                                    BorderThickness="4" 
                                    Background="{TemplateBinding Background}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A443E"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Window.Resources>

        <Grid>
            <Grid.Background>
                <DrawingBrush TileMode="Tile" Viewport="0,0,200,200" ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <DrawingGroup>
                            <GeometryDrawing Brush="#081818">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,200,200" />
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                            <GeometryDrawing Brush="#0A2222">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="100,0,100,100" />
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                            <GeometryDrawing Brush="#051212">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,100,100,100" />
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingGroup>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Grid.Background>

            <Rectangle Opacity="0.1">
                <Rectangle.Fill>
                    <VisualBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                        <VisualBrush.Visual>
                            <Rectangle Width="40" Height="40" Stroke="White" StrokeThickness="0.5"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Rectangle.Fill>
            </Rectangle>

            
            <StackPanel x:Name="McsrPanel" Margin="60,60,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                
               
                <Border BorderBrush="White" BorderThickness="5" Background="{StaticResource TitleBg}" Padding="20,20" Margin="0,0,0,60">
                    <StackPanel>
                        <TextBlock Text="MINECRAFT" 
                                   Foreground="{StaticResource TextGreen}" 
                                   FontSize="54" FontWeight="Black" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter"/>
                        <TextBlock Text="SPEEDRUNNING" 
                                   Foreground="{StaticResource TextGreen}" 
                                   FontSize="54" FontWeight="Black" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" Margin="0,-10,0,0"/>
                    </StackPanel>
                </Border>
                
            </StackPanel>
            
            
            
            
            <StackPanel x:Name="MainMenuPanel" Margin="60,200,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                
                

                    <ContentControl x:Name="PagePresenter" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,50,0,0">
                        <ContentControl.RenderTransform>
                            <TranslateTransform x:Name="PageTransform" X="1000"/> </ContentControl.RenderTransform>
                    </ContentControl>
                

                
                    <Button Content="GUIDES" Style="{StaticResource LargeMenuButtonStyle}" Width="550" Click = "BtnGuides_Click" />
                    <Button Content="FIND RESOURCES" Style="{StaticResource LargeMenuButtonStyle}" Width="550" Click = "BtnFindResources_Click" />
                    <Button Content="POST NEW RESOURCE" Style="{StaticResource LargeMenuButtonStyle}" Width="550" Click = "BtnPostResource_Click" />
                    <Button Content="QUIT" Style="{StaticResource LargeMenuButtonStyle}" Width="550" Click = "BtnQuit_Click" />

                
                
                
            </StackPanel>
            
            
            <StackPanel x:Name="GuidePanel" Margin="60,200,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="GuidesTransform" X="4000" />
                </StackPanel.RenderTransform>


                <ContentControl x:Name="MainMenuPresenter" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,50,0,0">
                    <ContentControl.RenderTransform>
                        <TranslateTransform x:Name="MainMenuTransform" X="1000"/> </ContentControl.RenderTransform>
                </ContentControl>
                
                <Button Content="This is the guide part" Style="{StaticResource LargeMenuButtonStyle}" Width="550" Click = "BtnGuides_Click" />
                <Button Content="BACK" Style="{StaticResource LargeMenuButtonStyle}" Click="BtnBack_Click"/>
            </StackPanel>
            
            
            
            <StackPanel x:Name="FindResourcesPanel" Visibility="Visible" Margin="60,250,50,0">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="FindResourcesTransform" X="4000" />
                </StackPanel.RenderTransform>

                <Border BorderBrush="White" BorderThickness="4" Background="{StaticResource TitleBg}" Padding="20" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="FIND RESOURCES" FontSize="36" Foreground="{StaticResource TextGreen}" FontWeight="Bold" Margin="0,0,0,15" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="SearchBox" Height="40" Background="#051212" Foreground="{StaticResource TextGreen}" 
                                     BorderBrush="White" BorderThickness="2" VerticalContentAlignment="Center" 
                                     Padding="10,0" FontSize="18" CaretBrush="White" Tag="Search for a guide or tool..." FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" />
                    
                                <Button Grid.Column="1" Content="SEARCH" Width="120" Height="40" Margin="10,0,0,0"
                            Style="{StaticResource LargeMenuButtonStyle}" FontSize="14"/>
                            </Grid>
                    </StackPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="500">
                    <ItemsControl x:Name="ResourcesList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                
                        <Border Width="250" Height="180" BorderBrush="White" BorderThickness="2" Margin="0,0,20,20" Background="#252525">
                            <Grid>
                                <TextBlock Text="Video Thumbnail Here" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555" />
                                <StackPanel VerticalAlignment="Bottom" Background="#AA000000" >
                                    <TextBlock Text="RSG 1.16.1 Guide" FontWeight="Bold" />
                                    <TextBlock Text="By SpecNR" FontSize="10" Foreground="#CCC" />
                                </StackPanel>
                            </Grid>
                        </Border>
                
                    </ItemsControl>
                </ScrollViewer>

                <Button Content="BACK" HorizontalAlignment="Left" Margin="0,20,0,0"
                Style="{StaticResource LargeMenuButtonStyle}" Click="BtnBackFromFind_Click"/>
            </StackPanel>
            
            
            
            
            <StackPanel x:Name="PostResourcePanel" Visibility="Visible" Margin="60,250,60,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="PostTransform" X="4000" />
                </StackPanel.RenderTransform>

                 <Border BorderBrush="White" BorderThickness="4" Background="{StaticResource TitleBg}" Padding="20" Margin="0,0,0,30" Width="700" HorizontalAlignment="Left">
                    <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="MY UPLOADED RESOURCES" FontSize="32" Foreground="{StaticResource TextGreen}" 
                               FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" />
                            <TextBlock Text="Manage and add new speedrun guides" FontSize="14" Foreground="White" Opacity="0.7"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="+" Width="60" Height="60" 
                        Style="{StaticResource LargeMenuButtonStyle}" Padding="0" FontSize="30" VerticalContentAlignment="Center" Click="BtnAddResource_Click" />
                        
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Height="400">
                    <ItemsControl x:Name="MyResourcesList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="250" Height="180" BorderBrush="White" BorderThickness="2" Margin="0,0,20,20" Background="#1A443E">
                                    <Grid>
                                        
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            
                                            <Grid Height="110" Width="250">
                                                <Image Source="{Binding idVideo }" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" Height="110" />
                                            </Grid>
                                            
                                            <Border Background="#CC051212" Height="36" BorderThickness="0,2,0,0" BorderBrush="White">
                                                <TextBlock Text="{Binding name}" 
                                                           Foreground="White" 
                                                           FontWeight="Bold" 
                                                           VerticalAlignment="Center" 
                                                           HorizontalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" 
                                                           Padding="5,0"
                                                           FontFamily="/ProjectMcsr;component/Resources/#Minecrafter"/>
                                            </Border>
                                            
                                            <Border Background="#051212" Height="36">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding EtoilesDifficulte }" 
                                                               Foreground="#FFD700" 
                                                               FontSize="20" 
                                                               FontFamily="Segoe UI Symbol"/>
 
                                                </StackPanel>
                                            </Border>
                                            
                                            
                                        </StackPanel>
                                        
                                        <Border BorderBrush="Black" 
                                                BorderThickness="2" 
                                                CornerRadius="2"
                                                HorizontalAlignment="Left" 
                                                VerticalAlignment="Bottom" 
                                                Margin="5,5,0,15" 
                                                Background="#80000000"> <Image Source="{Binding iconPath}" 
                                                                               Width="32" Height="32" 
                                                                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                        </Border>
                                        
                                        
                                        <Button Content="X" Width="25" Height="25" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                            Background="Red" Foreground="White" BorderThickness="1" Margin="5"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Content="BACK" HorizontalAlignment="Left" Margin="0,20,0,0"
                Style="{StaticResource LargeMenuButtonStyle}" Click="BtnBackFromPost_Click"/>
            </StackPanel>
            
            
            <StackPanel x:Name="CreateResourcePanel" Visibility="Visible" Margin="60,250,60,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="CreateTransform" X="4000" />
                </StackPanel.RenderTransform>

                <Border BorderBrush="White" BorderThickness="4" Background="{StaticResource TitleBg}" Padding="30" Width="600" HorizontalAlignment="Left">
                    <StackPanel>
                        <TextBlock Text="CREATE NEW RESOURCE" FontSize="28" Foreground="{StaticResource TextGreen}" 
                           FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" Margin="0,0,0,20" />

                        <TextBlock Text="RESOURCE NAME:" Foreground="{StaticResource TextGreen}" Margin="0,10,0,5" FontSize="14" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" />
                        <TextBox x:Name="InputName" Height="35" Background="#051212" Foreground="White" BorderBrush="White" BorderThickness="2" VerticalContentAlignment="Center" Padding="5,0"/>

                        <TextBlock Text="DESCRIPTION:" Foreground="{StaticResource TextGreen}" Margin="0,15,0,5" FontSize="14" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" />
                        <TextBox x:Name="InputDescription" Height="80" Background="#051212" Foreground="White" BorderBrush="White" BorderThickness="2" 
                         TextWrapping="Wrap" AcceptsReturn="True" Padding="5"/>

                        <TextBlock Text="YOUTUBE VIDEO LINK:" Foreground="{StaticResource TextGreen}" Margin="0,15,0,5" FontSize="14" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter"/>
                        <TextBox x:Name="InputVideoLink" Height="35" Background="#051212" Foreground="White" BorderBrush="White" BorderThickness="2" VerticalContentAlignment="Center" Padding="5,0"/>

                        <Grid Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Text="TYPE:" Foreground="{StaticResource TextGreen}" Margin="0,0,0,5" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" />
                                <ComboBox x:Name="InputType" Height="35" Background="#051212" BorderBrush="White" Foreground="{StaticResource TextGreen}" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" >
                                    <ComboBoxItem Content="Tutorial" Background="#051212" />
                                    <ComboBoxItem Content="Information" Background="#051212" />
                                    <ComboBoxItem Content="Other" Background="#051212"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="DIFFICULTY:" Foreground="{StaticResource TextGreen}" Margin="0,0,0,5" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" />
                                <ComboBox x:Name="InputDifficulty" Height="35" Background="#051212" BorderBrush="White" Foreground="{StaticResource TextGreen}" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" >
                                    <ComboBoxItem Content="Peaceful" Background="#051212"/>
                                    <ComboBoxItem Content="Easy" Background="#051212"/>
                                    <ComboBoxItem Content="Normal" Background="#051212" />
                                    <ComboBoxItem Content="Hard" Background="#051212" />
                                    <ComboBoxItem Content="Hardcore" Background="#051212" />
                                </ComboBox>
                                <TextBlock Text="TARGET SPLIT:" Foreground="{StaticResource TextGreen}" Margin="0,15,0,5" FontSize="14" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" />
                                <ComboBox x:Name="InputSplit" Height="35" Background="#051212" BorderBrush="#051212" Foreground="{StaticResource TextGreen}" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter">
                                    <ComboBoxItem Content="Overworld" Background="#051212" />
                                    <ComboBoxItem Content="Nether" Background="#051212" />
                                    <ComboBoxItem Content="Bastion" Background="#051212"/>
                                    <ComboBoxItem Content="Fortress" Background="#051212" />
                                    <ComboBoxItem Content="Blind Travel" Background="#051212" />
                                    <ComboBoxItem Content="Stronghold" Background="#051212" />
                                    <ComboBoxItem Content="The End" Background="#051212" />
                                </ComboBox>
                                
                            </StackPanel>
                            
                            
                            
                            
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
                            <Button Content="CANCEL" Width="150" Height="40" Style="{StaticResource LargeMenuButtonStyle}" 
                                    Padding="0" FontSize="14" Margin="0,0,15,0" Click="BtnCancelCreate_Click"/>
                            <Button Content="CONFIRM" Width="150" Height="40" Style="{StaticResource LargeMenuButtonStyle}" 
                                    Padding="0" FontSize="14" Margin="0,0,15,0" Click="BtnConfirmCreate_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            
            
            
        </Grid>
    </Window>