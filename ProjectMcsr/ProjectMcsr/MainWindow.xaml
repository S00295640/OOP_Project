<Window x:Class="ProjectMcsr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MCSR Ranked Hub" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#081818">

    <Window.Resources>
        <SolidColorBrush x:Key="TextGreen" Color="#99FF66" />
        <SolidColorBrush x:Key="TitleBg" Color="#122B27" />
        
        <Style x:Key="LargeMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#122B27"/>
            <Setter Property="Foreground" Value="{StaticResource TextGreen}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontFamily" Value="/ProjectMcsr;component/Resources/#Minecrafter"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="Padding" Value="30,25"/> <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border BorderBrush="White" 
                                BorderThickness="4" 
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A443E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,200,200" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#081818">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,200,200" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#0A2222">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="100,0,100,100" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing Brush="#051212">
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,100,100,100" />
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Grid.Background>

        <Rectangle Opacity="0.1">
            <Rectangle.Fill>
                <VisualBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute">
                    <VisualBrush.Visual>
                        <Rectangle Width="40" Height="40" Stroke="White" StrokeThickness="0.5"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Rectangle.Fill>
        </Rectangle>

        
        <StackPanel x:Name="McsrPanel" Margin="60,60,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
            
           
            <Border BorderBrush="White" BorderThickness="5" Background="{StaticResource TitleBg}" Padding="20,20" Margin="0,0,0,60">
                <StackPanel>
                    <TextBlock Text="MINECRAFT" 
                               Foreground="{StaticResource TextGreen}" 
                               FontSize="54" FontWeight="Black" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter"/>
                    <TextBlock Text="SPEEDRUNNING" 
                               Foreground="{StaticResource TextGreen}" 
                               FontSize="54" FontWeight="Black" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" Margin="0,-10,0,0"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
        
        
        
        
        <StackPanel x:Name="MainMenuPanel" Margin="60,200,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
            
            

                <ContentControl x:Name="PagePresenter" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,50,0,0">
                    <ContentControl.RenderTransform>
                        <TranslateTransform x:Name="PageTransform" X="1000"/> </ContentControl.RenderTransform>
                </ContentControl>
            

            
                <Button Content="GUIDES" Style="{StaticResource LargeMenuButtonStyle}" Width="550" Click = "BtnGuides_Click" />
                <Button Content="FIND RESOURCES" Style="{StaticResource LargeMenuButtonStyle}" Width="550" Click = "BtnFindResources_Click" />
                <Button Content="POST NEW RESOURCE" Style="{StaticResource LargeMenuButtonStyle}" Width="550" Click = "BtnPostResource_Click" />

            
            
            
        </StackPanel>
        
        
        <StackPanel x:Name="GuidePanel" Margin="60,200,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="GuidesTransform" X="4000" />
            </StackPanel.RenderTransform>


            <ContentControl x:Name="MainMenuPresenter" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="50,50,0,0">
                <ContentControl.RenderTransform>
                    <TranslateTransform x:Name="MainMenuTransform" X="1000"/> </ContentControl.RenderTransform>
            </ContentControl>
            
            <Button Content="This is the guide part" Style="{StaticResource LargeMenuButtonStyle}" Width="550" Click = "BtnGuides_Click" />
            <Button Content="BACK" Style="{StaticResource LargeMenuButtonStyle}" Click="BtnBack_Click"/>
        </StackPanel>
        
        
        
        <StackPanel x:Name="FindResourcesPanel" Visibility="Visible" Margin="60,250,50,0">
            <StackPanel.RenderTransform>
                <TranslateTransform x:Name="FindResourcesTransform" X="4000" />
            </StackPanel.RenderTransform>

            <Border BorderBrush="White" BorderThickness="4" Background="{StaticResource TitleBg}" Padding="20" Margin="0,0,0,30">
                <StackPanel>
                    <TextBlock Text="FIND RESOURCES" FontSize="36" Foreground="{StaticResource TextGreen}" FontWeight="Bold" Margin="0,0,0,15" FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SearchBox" Height="40" Background="#051212" Foreground="{StaticResource TextGreen}" 
                                 BorderBrush="White" BorderThickness="2" VerticalContentAlignment="Center" 
                                 Padding="10,0" FontSize="18" CaretBrush="White" Tag="Search for a guide or tool..." FontFamily="/ProjectMcsr;component/Resources/#Minecrafter" />
                
                            <Button Grid.Column="1" Content="SEARCH" Width="120" Height="40" Margin="10,0,0,0"
                        Style="{StaticResource LargeMenuButtonStyle}" FontSize="14"/>
                        </Grid>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="500">
                <ItemsControl x:Name="ResourcesList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
            
                    <Border Width="250" Height="180" BorderBrush="White" BorderThickness="2" Margin="0,0,20,20" Background="#252525">
                        <Grid>
                            <TextBlock Text="Video Thumbnail Here" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#555" />
                            <StackPanel VerticalAlignment="Bottom" Background="#AA000000" >
                                <TextBlock Text="RSG 1.16.1 Guide" FontWeight="Bold" />
                                <TextBlock Text="By SpecNR" FontSize="10" Foreground="#CCC" />
                            </StackPanel>
                        </Grid>
                    </Border>
            
                </ItemsControl>
            </ScrollViewer>

            <Button Content="BACK" HorizontalAlignment="Left" Width="200" Margin="0,20,0,0"
            Style="{StaticResource LargeMenuButtonStyle}" Click="BtnBackFromFind_Click"/>
</StackPanel>
        
        
        
        
        
        
    </Grid>
</Window>